# ============================================================================
# Marina WhatsApp Agent — environment template
# Copy to `.env` and fill in. Never commit `.env`.
# ============================================================================

# --- App ---
PUBLIC_BASE_URL=https://your-app.easypanel.host   # public HTTPS domain (EasyPanel)
PRICE_CENTS=2990                                   # R$29,90
TZ=America/Sao_Paulo
LOG_LEVEL=INFO
DEBOUNCE_SECONDS=4                                 # coalesce rapid WhatsApp bubbles
BUSINESS_HOURS_START=8                             # follow-ups not before this hour
BUSINESS_HOURS_END=21                              # ...nor after this hour
MAX_FREE_REGENERATIONS=1                           # free song re-generations per order

# --- OpenAI (LLM + STT) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_SONGWRITER_MODEL=gpt-4o-mini               # bump to gpt-4o if lyrics underperform
OPENAI_TRANSCRIBE_MODEL=gpt-4o-transcribe

# --- KIE.ai / Suno (music generation) ---
KIE_API_KEY=
KIE_BASE_URL=https://api.kie.ai
KIE_CALLBACK_URL=https://your-app.easypanel.host/webhooks/kie
KIE_POLL_INTERVAL=12
KIE_MAX_ATTEMPTS=30

# --- Evolution API (WhatsApp) ---
EVOLUTION_BASE_URL=                               # e.g. https://evo.yourdomain.com
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=                               # instance name
EVOLUTION_WEBHOOK_TOKEN=                          # shared secret to verify inbound webhooks

# --- Mercado Pago (PIX) ---
MP_ACCESS_TOKEN=
MP_WEBHOOK_SECRET=                                # secret for webhook signature validation

# --- Supabase (DB + Storage) ---
SUPABASE_URL=                                     # https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=                                  # SESSION pooler / direct conn (port 5432) for PostgresSaver
SUPABASE_STORAGE_BUCKET=marina-media

# --- EasyPanel (deploy) ---
EASYPANEL_API_URL=                                # https://your-easypanel-host (panel URL)
EASYPANEL_API_TOKEN=                              # API token so the agent can deploy
